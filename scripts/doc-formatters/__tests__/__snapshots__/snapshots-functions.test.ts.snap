                    border: '1px solid var(--ifm-color-emphasis-200)'
                }}>#strict</a>
  <a href="/use-cases?q=equality" style={{
                    display: 'inline-block',
                    padding: '2px 8px',
                    borderRadius: '12px',
                    backgroundColor: 'var(--ifm-color-emphasis-100)',
