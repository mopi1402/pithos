                    textDecoration: 'none',
                    fontSize: '0.85em',
                    border: '1px solid var(--ifm-color-emphasis-200)'
                }}>#array</a>
</div>

\`\`\`typescript
const items = [1, 2, 3, 4];
items[0];
// => 1
\`\`\`

### Get element at position

Access element at a specific index.

<div style={{display: 'flex', flexWrap: 'wrap', gap: '8px', marginTop: '8px', marginBottom: '16px'}}>
