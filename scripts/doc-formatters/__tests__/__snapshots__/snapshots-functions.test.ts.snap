exports[`Functions — taphos (lodash compat) > flatten (taphos) 1`] = `
"# ~~flatten()~~

> **flatten**\\<\`T\`\\>(\`array\`): (\`T\` \\| \`T\`[])[]

Flattens array a single level deep.

:::warning DEPRECATED

Use \`array.flat()\` directly instead.

> **Reason**:<br/>
> Native equivalent method now available

:::


---

## Type Parameters

### T: \`T\`

The type of elements in the array.

---

## Parameters

### array: \`(T | T[])[]\`

The array to flatten.

---

## Returns: \`(T | T[])[]\`

A new flattened array.


---

## See Also

- [Array.flat() - MDN](https://developer.mozilla.org/en-US/docs/Web/JavaScript/Reference/Global_Objects/Array/flat)
 - [Browser support - Can I Use](https://caniuse.com/mdn-javascript_builtins_array_flat)

---

## Since

2.0.0

---

## Also known as

<AlsoKnownAs data={{"lodash":{"name":"flatten","group":"Array"},"ramda":{"name":"flatten","group":"List"},"radashi":{"name":"flat","group":"Array"},"remeda":{"name":"flat","group":"Array"},"moderndash":null,"antfu":{"name":"flattenArrayable","group":"array"},"effect":{"name":"flatten","group":"Array"},"es-toolkit":{"name":"flatten","group":"array"},"python":{"name":"chain.from_iterable","group":"itertools"},"kotlin":{"name":"flatten","group":"collections"}}} />


---

## Example

\`\`\`typescript
const nested = [1, [2, 3], [4, [5, 6]]];

// ❌ Deprecated approach
const flattened = flatten(nested);
console.log(flattened); // [1, 2, 3, 4, [5, 6]]

// ✅ Recommended approach
const flattenedNative = nested.flat();
console.log(flattenedNative); // [1, 2, 3, 4, [5, 6]]
\`\`\`

---

## How it works?

Flattens array a single level deep.
**Deprecated**: Use \`array.flat()\` directly (ES2019).
<ResponsiveMermaid
  desktop={\`flowchart LR
    A["[1, [2, 3], [4, [5, 6]]]"] --> B["flatten(_)"]
    B --> C["[1, 2, 3, 4, [5, 6]]"]\`}
  mobile={\`flowchart TB
    A["[1, [2, 3], [4, [5, 6]]]"] --> B["flatten(_)"]
    B --> C["[1, 2, 3, 4, [5, 6]]"]\`}
/>

### Single Level Only
<ResponsiveMermaid
  desktop={\`flowchart LR
    subgraph "Before"
        A["[1, [2, 3], [4, [5]]]"]
    end
    subgraph "After flatten()"
        B["[1, 2, 3, 4, [5]]"]
    end
    A --> B\`}
  mobile={\`flowchart TB
    subgraph "Before"
        A["[1, [2, 3], [4, [5]]]"]
    end
    subgraph "After flatten()"
        B["[1, 2, 3, 4, [5]]"]
    end
    A --> B\`}
/>

### Native Equivalent

\`\`\`typescript
// ❌ flatten(arr)
// ✅ arr.flat()
\`\`\`

---

## Use Cases

