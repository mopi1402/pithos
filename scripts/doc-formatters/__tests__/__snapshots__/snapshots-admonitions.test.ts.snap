\`\`\`typescript
const countdown = async (seconds: number, onTick: (remaining: number) => void) => {
  for (let i = seconds; i > 0; i--) {
    onTick(i);
    await sleep(1000);
  }
  onTick(0);
};

await countdown(3, (n) => {
  display.textContent = n === 0 ? "Go!" : String(n);
});
startGame();
\`\`\`

