                }}>#ci/cd</a>
</div>

\`\`\`typescript
// Retry database operations
const result = await retry(
  async () => {
    return await database.query("SELECT * FROM users WHERE active = ?", [true]);
  },
  {
    attempts: 3,
    delay: 500,
    backoff: 1.5,
    until: (error) => error.code === "CONNECTION_TIMEOUT",
  }
);

console.log(\`Found \${result.length} active users\`);
\`\`\`

