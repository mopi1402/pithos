                    border: '1px solid var(--ifm-color-emphasis-200)'
                }}>#accumulate</a>
  <a href="/use-cases?q=stabilize" style={{
                    display: 'inline-block',
                    padding: '2px 8px',
                    borderRadius: '12px',
                    backgroundColor: 'var(--ifm-color-emphasis-100)',
                    color: 'var(--ifm-color-content)',
                    textDecoration: 'none',
                    fontSize: '0.85em',
                    border: '1px solid var(--ifm-color-emphasis-200)'
