  analytics.send({
    action: get(event, "action", "unknown"),
    category: get(event, "metadata.category", "uncategorized"),
    label: get(event, "metadata.label"),
    value: get(event, "metadata.value", 0),
    userId: get(event, "user.id"),
  });
};
