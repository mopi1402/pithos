\`\`\`typescript
const criticalAssets = [
  "/index.html", "/app.js", "/styles.css",
  "/icons/logo.svg", "/fonts/inter.woff2",
  "/api/config", "/api/translations/en",
];

const preloadAll = async () => {
  const cache = await caches.open("v1");
  await parallel(
    criticalAssets.map((url) => async () => {
      const response = await fetch(url);
      await cache.put(url, response);
    }),
    3 // Max 3 concurrent fetches
  );
};
\`\`\`

"
`;

exports[`Admonitions — @throws > sleep (@throws) 1`] = `
"# sleep()

> **sleep**(\`ms\`): \`Promise\`\\<\`void\`\\>

Pauses execution for a specified duration.


---

## Parameters

### ms: \`number\`

Duration to sleep in milliseconds (must be non-negative).

---

## Returns: \`Promise<void>\`

Promise that resolves after the specified duration.


---

## Throws

\`RangeError\` If ms is negative.

---

## Since

2.0.0

---

## Also known as

<AlsoKnownAs data={{"lodash":null,"ramda":null,"radashi":{"name":"sleep","group":"Async"},"remeda":null,"moderndash":{"name":"sleep","group":"Promise"},"antfu":{"name":"sleep","group":"promise"},"effect":{"name":"sleep","group":"Effect"},"es-toolkit":{"name":"delay","group":"promise"},"python":{"name":"sleep","group":"asyncio"},"kotlin":{"name":"delay","group":"coroutines"}}} />


---

## Example

\`\`\`typescript
await sleep(1000);
console.log('1 second later');

// Sequential delays
for (const item of items) {
  await process(item);
  await sleep(100);
}
\`\`\`

---

## How it works?

Pauses execution for a specified duration.
Returns a Promise that resolves after the delay.
\`\`\`mermaid
sequenceDiagram
    participant C as Code
    participant S as sleep
    participant T as Timer
    
    C->>S: await sleep(1000)
    S->>T: setTimeout(1000ms)
    Note right of T: ⏳ waiting...
    T-->>S: ✅ timeout
    S-->>C: Promise resolves
\`\`\`

### Usage
<ResponsiveMermaid
  desktop={\`flowchart LR
    A["await sleep(1000)"] --> B["⏳ 1 second"]
    B --> C["continue execution"]\`}
  mobile={\`flowchart TB
    A["await sleep(1000)"] --> B["⏳ 1 second"]
    B --> C["continue execution"]\`}
/>

### Sequential Delays
<ResponsiveMermaid
  desktop={\`flowchart LR
    A["process(item1)"] --> B["sleep(100)"]
    B --> C["process(item2)"]
    C --> D["sleep(100)"]
    D --> E["process(item3)"]\`}
  mobile={\`flowchart TB
    A["process(item1)"] --> B["sleep(100)"]
    B --> C["process(item2)"]
    C --> D["sleep(100)"]
    D --> E["process(item3)"]\`}
/>

Rate limiting between operations.

---

## Use Cases

### Delay async execution 📌

Pause async execution for a specific duration.
Essential for throttling, polling intervals, or simulating latency in tests.

