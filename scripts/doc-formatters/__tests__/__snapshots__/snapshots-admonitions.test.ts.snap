const getInitials = (name: string) =>
  deburr(name)
    .split(" ")
    .map((part) => part[0])
    .join("")
    .toUpperCase();

getInitials("Rene Descartes"); // => "RD"
getInitials("Jose Garcia");    // => "JG"
\`\`\`

