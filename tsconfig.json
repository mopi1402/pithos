{
  "extends": "./tsconfig.build.json",
  "compilerOptions": {
    "rootDir": ".",
    "noEmit": true
  },
  "include": [
    "packages/pithos/src/**/*",
    "packages/pithos/test/**/*",
    "vitest.setup.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "tmp",
    "packages/tmp",
    "packages/main/integrations",
    ".stryker-tmp",
    ".stryker-tmp-manual",
    "vendor"
  ]
}
