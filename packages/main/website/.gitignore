# Dependencies
/node_modules

# Production
/build

# Generated files
.docusaurus
.cache-loader

# Generated images (regenerated from assets/ at build time)
/static/img/generated/
/static/img/emoji/

# Generated demos (built from examples at build time)
/static/demos/

# Generated use cases data (should be regenerated at build time)
/static/use_cases/*.json

# Generated pre-computed comparisons (regenerated at build time)
/src/data/generated/pre-computed-comparisons.ts

# Changelog copies (regenerated from root CHANGELOG.md by scripts/copy-changelog.ts)
/docs/basics/changelog.md
/i18n/**/basics/changelog.md

# Misc
.DS_Store
.env.local
.env.development.local
.env.test.local
.env.production.local

npm-debug.log*
yarn-debug.log*
yarn-error.log*
.vercel
